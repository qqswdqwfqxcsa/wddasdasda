function MystrixHub.FarmController.FlyPath(root, speedMultiplier)
    local path = {
        Vector3.new(675, -7, 237),
        Vector3.new(675, 3, 237),
        Vector3.new(703, 3, 239)
    }
    local baseSpeed = 20
    for _, target in ipairs(path) do
        local startPos = root.Position
        local distance = (target - startPos).Magnitude
        local duration = distance / (baseSpeed * speedMultiplier)
        if duration <= 0 then duration = 0.01 end
        local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(target)})
        tween:Play()
        tween.Completed:Wait()
    end
end
MystrixHub.FarmController.Start = function()
    if MystrixHub.FarmController.Running then return end
    MystrixHub.FarmController.Running = true
    MystrixHub.FarmController.IsCollecting = false

    MystrixHub.FarmController.Loop = task.spawn(function()
        while MystrixHub.FarmController.Running do
            local success, err = pcall(function()
                MystrixHub.FarmController.IsCollecting = false

                local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local root = char:WaitForChild("HumanoidRootPart", 10)
                if not root then return end

                root.CFrame = CFrame.new(690, 3, 238)
                task.wait(0.5)

                MystrixHub.Functions.FireRemote("rev_KickEvent", 1)
                task.wait(0.5)

                local attr      = LocalPlayer:GetAttribute("InGame")
                local satisfied = MystrixHub.FarmController.IsConditionMet(attr)

                local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD") or LocalPlayer.PlayerGui:WaitForChild("HUD")
                local runGui = hud:FindFirstChild("Run")
                if runGui then
                    local waited = 0
                    repeat
                        task.wait(0.1)
                        waited = waited + 0.1
                        if waited > 10 then break end
                    until runGui.Visible
                    if not runGui.Visible then return end
                end

                if satisfied then
                    MystrixHub.FarmController.IsCollecting = true

                    local function getTools()
                        local t = {}
                        if char then
                            for _, obj in ipairs(char:GetChildren()) do
                                if obj:IsA("Tool") then t[obj] = true end
                            end
                        end
                        local back = LocalPlayer.Backpack
                        if back then
                            for _, obj in ipairs(back:GetChildren()) do
                                if obj:IsA("Tool") then t[obj] = true end
                            end
                        end
                        return t
                    end

                    local oldTools = getTools()

                    if root and root.Parent then
                        MystrixHub.FarmController.FlyPath(root, MystrixHub.FarmController.TweenSpeedMultiplier)
                    end

                    repeat
                        task.wait(0.5)
                        char = LocalPlayer.Character
                        local currentTools = getTools()
                        local newTool = nil
                        for tool in pairs(currentTools) do
                            if not oldTools[tool] then
                                newTool = tool
                                break
                            end
                        end
                    until newTool
                else
                    task.wait(0.5)
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        hum.Health = 0
                    end
                    local newChar = LocalPlayer.CharacterAdded:Wait()
                    if newChar then
                        newChar:WaitForChild("HumanoidRootPart", 10)
                    end
                end
            end)

            if not success then
                warn("[Auto Farm Error]", err)
            end
            task.wait(1)
        end
    end)

    task.spawn(function()
        while MystrixHub.FarmController.Running do
            MystrixHub.Functions.FireRemote("rev_KickZman")
            task.wait(0.1)
        end
    end)
end
