function MystrixHub.Functions.GetRarityOfBrainrot(name)
    local farmRarities = {"Common","Rare","Epic","Legendary","Mythic","Godly","Secret","OG","Hacked","Divine","Celestial"}
    for _, rarity in ipairs(farmRarities) do
        local names = MystrixHub.RarityData[rarity]
        if names then
            for _, n in ipairs(names) do
                if n == name then return rarity end
            end
        end
    end
    return nil
end

function MystrixHub.FarmController.IsMutationOk(mutation)
    for _, m in ipairs(MystrixHub.FarmController.SelectedMutations) do
        if m == "Any" then return true end
    end
    local hasNone = false
    for _, m in ipairs(MystrixHub.FarmController.SelectedMutations) do
        if m == "None" then hasNone = true break end
    end
    if hasNone and (mutation == "" or mutation == "None") then return true end
    for _, m in ipairs(MystrixHub.FarmController.SelectedMutations) do
        if m == mutation then return true end
    end
    return false
end

function MystrixHub.FarmController.IsConditionMet(attr)
    if not attr or attr == "" then return false end
    local parts = {}
    for part in attr:gmatch("[^,]+") do
        table.insert(parts, part:match("^%s*(.-)%s*$"))
    end
    if #parts < 2 then return false end
    local name     = parts[1]
    local mutation = parts[2]
    if #MystrixHub.FarmController.SelectedSpecific > 0 then
        for _, sel in ipairs(MystrixHub.FarmController.SelectedSpecific) do
            if sel == name then
                return MystrixHub.FarmController.IsMutationOk(mutation)
            end
        end
        return false
    end
    if #MystrixHub.FarmController.SelectedRarities == 0 then return false end
    local rarity = MystrixHub.Functions.GetRarityOfBrainrot(name)
    if not rarity then return false end
    for _, r in ipairs(MystrixHub.FarmController.SelectedRarities) do
        if r == rarity then
            return MystrixHub.FarmController.IsMutationOk(mutation)
        end
    end
    return false
end

