function MystrixHub.Functions.GetOccupiedSlotsSorted(plot)
    local slots = {}
    local slotsFolder = plot:FindFirstChild("Slots")
    if not slotsFolder then return slots end
    for _, slotPart in ipairs(slotsFolder:GetChildren()) do
        if slotPart:IsA("BasePart") and slotPart:FindFirstChild("PlacedPart") then
            local num = tonumber(slotPart.Name:match("%d+"))
            if num then table.insert(slots, {part = slotPart, num = num}) end
        end
    end
    table.sort(slots, function(a, b) return a.num < b.num end)
    local sortedParts = {}
    for _, entry in ipairs(slots) do table.insert(sortedParts, entry.part) end
    return sortedParts
end

function MystrixHub.Functions.GetMatchingSlots(rarityName)
    local plot = MystrixHub.Functions.GetPlayerPlot()
    if not plot then return {} end
    local ids = MystrixHub.RarityData[rarityName]
    if not ids then return {} end
    local idSet = {}
    for _, id in ipairs(ids) do idSet[id] = true end
    local matches = {}
    for _, slot in ipairs(MystrixHub.Functions.GetOccupiedSlotsSorted(plot)) do
        local placed = slot:FindFirstChild("PlacedPart")
        if placed then
            local name = placed:GetAttribute("ID")
            if name and idSet[name] then table.insert(matches, slot) end
        end
    end
    return matches
end

function MystrixHub.Functions.UpgradeSlotsSequentially(slots)
