function MystrixHub.Functions.HexToBytes(hex)
    return (hex:gsub("..", function(cc) return string.char(tonumber(cc, 16)) end))
end

function MystrixHub.Functions.BytesToHex(s)
    return (s:gsub(".", function(c) return string.format("%02x", string.byte(c)) end))
end

function MystrixHub.Functions.IsHex(s, n)
    if not s then return false end
    if n and #s ~= n then return false end
    return s:match("^[0-9a-fA-F]+$") ~= nil
end

function MystrixHub.Functions.NormaliseSHA256(r)
    if not r or r == "" then return nil end
    if #r == 64 and MystrixHub.Functions.IsHex(r, 64) then return MystrixHub.Functions.HexToBytes(r)
    elseif #r == 32 then return r
    elseif MystrixHub.Functions.IsHex(r) then return MystrixHub.Functions.HexToBytes(r) end
    return r
end

function MystrixHub.Functions.SHA256Bytes(data)
    local ok, result
    ok, result = pcall(function() return crypt and crypt.hash and crypt.hash(data, "sha256") end)
    if ok and result and result ~= "" then local n = MystrixHub.Functions.NormaliseSHA256(result) if n then return n end end
    ok, result = pcall(function() return HttpService:SHA256(data) end)
    if ok and result and result ~= "" then local n = MystrixHub.Functions.NormaliseSHA256(result) if n then return n end end
    ok, result = pcall(function() return crypto and crypto.sha256 and crypto.sha256(data) end)
    if ok and result and result ~= "" then local n = MystrixHub.Functions.NormaliseSHA256(result) if n then return n end end
    return nil
end

function MystrixHub.Functions.SHA256(data)
    local b = MystrixHub.Functions.SHA256Bytes(data)
    if not b then return "" end
    return MystrixHub.Functions.BytesToHex(b)
end

function MystrixHub.Functions.HMACSHA256(key, message)
    local block_size = 64
    local keyBytes = (#key > block_size) and MystrixHub.Functions.SHA256Bytes(key) or key
    if not keyBytes then return "" end
    while #keyBytes < block_size do keyBytes = keyBytes .. "\0" end
    local ipad, opad = {}, {}
    for i = 1, block_size do
        local b = string.byte(keyBytes, i)
        ipad[i] = string.char(bit32.bxor(b, 0x36))
        opad[i] = string.char(bit32.bxor(b, 0x5c))
    end
    local innerHash = MystrixHub.Functions.SHA256Bytes(table.concat(ipad) .. message)
    if not innerHash then return "" end
    return MystrixHub.Functions.SHA256(table.concat(opad) .. innerHash)
end

function MystrixHub.Functions.CleanKey(key)
    if not key then return "" end
    key = tostring(key)
    key = key:match("^%s*(.-)%s*$")
    key = key:gsub("[%z\1-\8\11\12\14-\31\127]", "")
    key = key:gsub("\226\128\139", "")
    key = key:gsub("\226\128\138", "")
    key = key:gsub("\239\187\191", "")
    key = key:gsub("[^%w%-_]", "")
    return key
end

function MystrixHub.Functions.MakeRawRequest(url, method, headers, body)
    local args = { Url = url, Method = method or "GET" }
    if headers then args.Headers = headers end
    if body    then args.Body    = body    end
    if request then local ok, r = pcall(request, args) if ok and r then return r end end
    if syn and syn.request then local ok, r = pcall(syn.request, args) if ok and r then return r end end
    if http and http.request then local ok, r = pcall(http.request, args) if ok and r then return r end end
    if http_request then local ok, r = pcall(http_request, args) if ok and r then return r end end
    return nil
end

function MystrixHub.Functions.TryParseUnixMs(resp)
    if not (resp and resp.Body) then return nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(resp.Body) end)
    if not ok or not data then return nil end
    if data.unixtime     then return math.floor(data.unixtime * 1000) end
    if data.now          then return math.floor(data.now * 1000) end
    if data.dateTime     then local ok2, dt = pcall(function() return DateTime.fromIsoDate(data.dateTime) end) if ok2 and dt then return dt.UnixTimestampMillis end end
    if data.utc_datetime then local ok2, dt = pcall(function() return DateTime.fromIsoDate(data.utc_datetime) end) if ok2 and dt then return dt.UnixTimestampMillis end end
    return nil
end

function MystrixHub.Functions.TryParseDateHeader(resp)
    if not (resp and resp.Headers) then return nil end
    local dh = resp.Headers["date"] or resp.Headers["Date"]
    if not dh then return nil end
    local day, mon, year, h, m, s = dh:match("(%d+) (%a+) (%d+) (%d+):(%d+):(%d+)")
    local months = {Jan=1,Feb=2,Mar=3,Apr=4,May=5,Jun=6,Jul=7,Aug=8,Sep=9,Oct=10,Nov=11,Dec=12}
    if day and mon and year and months[mon] then
        local ok, ts = pcall(os.time, {year=tonumber(year),month=months[mon],day=tonumber(day),hour=tonumber(h),min=tonumber(m),sec=tonumber(s)})
        if ok then return ts * 1000 end
    end
    return nil
end

function MystrixHub.Functions.SyncServerTime()
    local TC = MystrixHub.TimeController
    if TC.CachedOffset ~= nil and (os.time() - TC.LastSync) < 60 then return true end
    for _, url in ipairs({"https://worldtimeapi.org/api/timezone/Etc/UTC","https://timeapi.io/api/Time/current/zone?timeZone=UTC"}) do
        local ok, resp = pcall(MystrixHub.Functions.MakeRawRequest, url, "GET", {["Accept"]="application/json"}, nil)
        if ok and resp then local ms = MystrixHub.Functions.TryParseUnixMs(resp) if ms then TC.CachedOffset = ms - DateTime.now().UnixTimestampMillis TC.LastSync = os.time() return true end end
    end
    for _, url in ipairs({"https://www.google.com/","https://www.roblox.com/","https://discord.com/"}) do
        local ok, resp = pcall(MystrixHub.Functions.MakeRawRequest, url, "GET", nil, nil)
        if ok and resp then local ms = MystrixHub.Functions.TryParseDateHeader(resp) if ms then TC.CachedOffset = ms - DateTime.now().UnixTimestampMillis TC.LastSync = os.time() return true end end
    end
    TC.CachedOffset = 0 TC.LastSync = os.time() return false
end

function MystrixHub.Functions.GetAccurateTimestampMs(extra)
    local TC = MystrixHub.TimeController
    if TC.CachedOffset == nil then MystrixHub.Functions.SyncServerTime() end
    return tostring(DateTime.now().UnixTimestampMillis + (TC.CachedOffset or 0) + (extra or 0))
end

function MystrixHub.Functions.GetHWID()
    local hwid
    for _, m in ipairs({
        function() return gethwid and gethwid() end,
        function() return game:GetService("RbxAnalyticsService"):GetClientId() end,
        function() return game:GetService("UserIdService"):GetUserId() end,
    }) do
        local ok, r = pcall(m)
        if ok and r and r ~= "" then hwid = tostring(r) break end
    end
    if not hwid or hwid == "" then
        local uid = LocalPlayer and LocalPlayer.UserId or 0
        hwid = MystrixHub.Functions.SHA256("USER_" .. uid .. "_" .. game.PlaceId):sub(1, 32)
    end
    return hwid
end

function MystrixHub.Functions.BuildAndSendRequest(bodyString, bodyHash, extra)
    local ts        = MystrixHub.Functions.GetAccurateTimestampMs(extra)
    local nonce     = HttpService:GenerateGUID(false):gsub("-", "")
    local canonical = "POST\n/keys/verify\n" .. ts .. "\n" .. nonce .. "\n" .. bodyHash
    local sig       = MystrixHub.Functions.HMACSHA256(MystrixHub.Auth.SigningSecret, canonical)
    return MystrixHub.Functions.MakeRawRequest(MystrixHub.Auth.BaseURL .. "/api/v1/keys/verify", "POST", {
        ["Content-Type"]  = "application/json",
        ["Authorization"] = "Bearer " .. MystrixHub.Auth.ApiToken,
        ["X-Timestamp"]   = ts,
        ["X-Nonce"]       = nonce,
        ["X-Signature"]   = sig,
        ["X-Body-Sha256"] = bodyHash,
        ["X-Hwid"]        = MystrixHub.Functions.GetHWID() or ""
    }, bodyString)
end

function MystrixHub.Functions.VerifyKey(userKey)
    userKey = MystrixHub.Functions.CleanKey(userKey)
    if not userKey or #userKey < 10 then return false, "INVALID_KEY" end
    local hwid       = MystrixHub.Functions.GetHWID()
    local reqBody    = { key = userKey, requestId = HttpService:GenerateGUID(false):gsub("-","") }
    if hwid and hwid ~= "" then reqBody.hwid = hwid end
    local bodyString = HttpService:JSONEncode(reqBody)
    local bodyHash   = MystrixHub.Functions.SHA256(bodyString)
    local resp       = MystrixHub.Functions.BuildAndSendRequest(bodyString, bodyHash, 0)
    local statusCode = resp and resp.StatusCode
    local response   = resp and resp.Body
    if statusCode == 401 then
        MystrixHub.TimeController.CachedOffset = nil
        MystrixHub.TimeController.LastSync = 0
        MystrixHub.Functions.SyncServerTime()
        for _, offset in ipairs({0, 30000, -30000, 60000, -60000}) do
            resp       = MystrixHub.Functions.BuildAndSendRequest(bodyString, bodyHash, offset)
            statusCode = resp and resp.StatusCode
            response   = resp and resp.Body
            if statusCode ~= 401 then break end
        end
    end
    if not response then return false, "NETWORK_ERROR" end
    local ok, data = pcall(function() return HttpService:JSONDecode(response) end)
    if not ok then return false, "NETWORK_ERROR" end
    if data and data.valid then
        return true, {
            keyId      = data.keyId,
            label      = data.label or "Key",
            validUntil = data.validUntil,
            expiresIn  = data.expiresIn,
            hwid       = data.hwid,
            hwidReset  = data.hwidReset or false,
            uses       = data.uses or data.executionCount or nil,
        }
    end
    return false, data and data.reason or "INVALID_KEY"
end

function MystrixHub.Functions.FormatTimeRemaining(seconds)
    if seconds <= 0 then return "Expired" end
    local d = math.floor(seconds / 86400)
    local h = math.floor((seconds % 86400) / 3600)
    local m = math.floor((seconds % 3600) / 60)
    if d > 0 then return d .. "d " .. h .. "h remaining"
    elseif h > 0 then return h .. "h " .. m .. "m remaining"
    elseif m > 0 then return m .. "m remaining"
    else return "Less than a minute" end
end

function MystrixHub.Functions.FormatExpiry(isoDate)
    if not isoDate then return nil, nil end
    local ok, dt = pcall(function() return DateTime.fromIsoDate(isoDate) end)
    if not (ok and dt) then return nil, nil end
    local t = os.date("*t", dt.UnixTimestamp)
    return string.format("%02d/%02d/%d at %02d:%02d UTC", t.month, t.day, t.year, t.hour, t.min),
           dt.UnixTimestamp - os.time()
end

