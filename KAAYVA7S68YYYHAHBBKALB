local ConfigSection = RightVStack:Section({ Title = "Config", Icon = "save", Box = true, Opened = true })

ConfigSection:Input({
    Title       = "Config Name",
    Icon        = "pencil",
    Placeholder = "MystrixHub",
    Callback    = function(value)
        MystrixHub.ConfigController.NameInput = (value and value ~= "") and value or "MystrixHub"
    end
})

ConfigSection:Button({
    Title    = "Save Config",
    Icon     = "save",
    Callback = function()
        task.spawn(function()
            local configToSave = MystrixHub.ConfigController.GetConfig(MystrixHub.ConfigController.NameInput)
            local ok, err = pcall(function() configToSave:Save() end)
            if ok then MystrixHub.ConfigController.SaveLastConfigName(MystrixHub.ConfigController.NameInput) end
            WindUI:Notify({
                Title    = ok and "Config Saved" or "Save Failed",
                Content  = ok and ("Saved as: " .. MystrixHub.ConfigController.NameInput) or tostring(err),
                Duration = 3,
                Icon     = ok and "check-circle" or "alert-circle",
            })
            if ok and MystrixHub.ConfigController.Dropdown then
                MystrixHub.ConfigController.Dropdown:Refresh(MystrixHub.ConfigController.GetAllConfigNames())
            end
        end)
    end
})

ConfigSection:Divider()

local initialConfigs = MystrixHub.ConfigController.GetAllConfigNames()

MystrixHub.ConfigController.Dropdown = ConfigSection:Dropdown({
    Title    = "Select Config",
    Icon     = "folder-open",
    Values   = initialConfigs,
    Multi    = false,
    Value    = initialConfigs[1] or "No configs found",
    Callback = function(value)
        MystrixHub.ConfigController.SelectedConfig = (value ~= "No configs found") and value or nil
    end
})

ConfigSection:Button({
    Title    = "Refresh Config List",
    Icon     = "refresh-cw",
    Callback = function()
        MystrixHub.ConfigController.Dropdown:Refresh(MystrixHub.ConfigController.GetAllConfigNames())
        WindUI:Notify({ Title = "Refreshed", Content = "Config list has been updated!", Duration = 2, Icon = "check-circle" })
    end
})

ConfigSection:Button({
    Title    = "Load Selected Config",
    Icon     = "folder-open",
    Callback = function()
        if not MystrixHub.ConfigController.SelectedConfig then
            WindUI:Notify({ Title = "No Config Selected", Content = "Please select a config from the dropdown first!", Duration = 3, Icon = "alert-circle" })
            return
        end
        WindUI:Notify({ Title = "Loading Config", Content = "Loading: " .. MystrixHub.ConfigController.SelectedConfig .. ", please wait...", Duration = 3, Icon = "loader-2" })
        task.spawn(function()
            local configToLoad = MystrixHub.ConfigController.GetConfig(MystrixHub.ConfigController.SelectedConfig)
            local ok, err = pcall(function() configToLoad:Load() end)
            if ok then MystrixHub.ConfigController.SaveLastConfigName(MystrixHub.ConfigController.SelectedConfig) end
            WindUI:Notify({
                Title    = ok and "Config Loaded" or "Load Failed",
                Content  = ok and ("Loaded: " .. MystrixHub.ConfigController.SelectedConfig) or tostring(err),
                Duration = 3,
                Icon     = ok and "check-circle" or "alert-circle",
            })
        end)
    end
})

ConfigSection:Button({
    Title    = "Delete Selected Config",
    Icon     = "trash-2",
    Callback = function()
        if not MystrixHub.ConfigController.SelectedConfig then
            WindUI:Notify({ Title = "No Config Selected", Content = "Please select a config from the dropdown first!", Duration = 3, Icon = "alert-circle" })
            return
        end
        task.spawn(function()
            local configToDelete = MystrixHub.ConfigController.GetConfig(MystrixHub.ConfigController.SelectedConfig)
            local ok, err = pcall(function() configToDelete:Delete() end)
            WindUI:Notify({
                Title    = ok and "Config Deleted" or "Delete Failed",
                Content  = ok and ("Deleted: " .. MystrixHub.ConfigController.SelectedConfig) or tostring(err),
                Duration = 3,
                Icon     = ok and "check-circle" or "alert-circle",
            })
            if ok then
                MystrixHub.ConfigController.Cache[MystrixHub.ConfigController.SelectedConfig] = nil
                local lastConfig = MystrixHub.ConfigController.LoadLastConfigName()
                if lastConfig == MystrixHub.ConfigController.SelectedConfig then
                    pcall(function() if writefile then writefile(MystrixHub.ConfigController.LastConfigFile, "") end end)
                end
                MystrixHub.ConfigController.SelectedConfig = nil
                MystrixHub.ConfigController.Dropdown:Refresh(MystrixHub.ConfigController.GetAllConfigNames())
            end
        end)
    end
})

ConfigSection:Divider()

