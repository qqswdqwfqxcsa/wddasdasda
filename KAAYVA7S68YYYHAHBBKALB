            return
        end
        WindUI:Notify({ Title = "Loading Last Config", Content = "Loading: " .. lastConfig .. "...", Duration = 2, Icon = "loader-2" })
        task.spawn(function()
            local configToLoad = MystrixHub.ConfigController.GetConfig(lastConfig)
            local ok, err = pcall(function() configToLoad:Load() end)
            if ok then MystrixHub.ConfigController.SaveLastConfigName(lastConfig) end
            WindUI:Notify({
                Title    = ok and "Config Loaded" or "Load Failed",
                Content  = ok and ("Loaded: " .. lastConfig) or tostring(err),
                Duration = 3,
                Icon     = ok and "check-circle" or "alert-circle",
            })
        end)
    end
})

